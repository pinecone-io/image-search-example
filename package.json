{
  "name": "pinecone-image-search-example",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev:server": "nodemon --watch 'server/**/*.ts' --exec 'tsx' server/index.ts",
    "dev:app": "vite --config app/vite.config.ts",
    "dev": "npm run dev:app & npm run dev:server",
    "build:app": "tsc && vite build app",
    "lint": "eslint app/src/ server/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "vitest run --project server",
    "test:app": "vitest run --project app"
  },
  "keywords": [
    "starter",
    "template",
    "node",
    "typescript",
    "llm",
    "image search"
  ],
  "author": "Roie Schwaber-Cohen",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@pinecone-database/pinecone": "^8.0.0",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "console-table-printer": "^2.11.1",
    "cross-fetch": "^3.1.6",
    "dotenv": "^16.1.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "http-proxy-middleware": "^3.0.0-beta.1",
    "multer": "^2.2.0",
    "nodemon": "^3.0.1",
    "onnxruntime-node": "^1.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "sonner": "^1.4.41"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.17",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.20.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^5.51.0",
    "@typescript-eslint/parser": "^5.51.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.33.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "jsdom": "^27.0.1",
    "nock": "^14.0.16",
    "postcss": "^8.4.27",
    "prettier": "^2.8.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.3.3",
    "tsx": "^4.23.0",
    "typescript": "^5.2.0",
    "vite": "^8.1.3",
    "vitest": "^3.2.7"
  }
}
